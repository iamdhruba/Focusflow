# ──────────────────────────────────────────────────────────────────────────────
# FocusFlow Backend — Environment Configuration
# ──────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/focusflow

# ── Authentication ────────────────────────────────────────────────────────────
# Secrets can be generated via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_access_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# For Gmail, use an "App Password" (dqwo hmpq ttxd ymez style)
SMTP_EMAIL=dhrubarajchaudhary498@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=FocusFlow Security
SMTP_FROM_EMAIL=dhrubarajchaudhary498@gmail.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of origins (e.g., http://localhost:3000)
# Leave empty to allow all in development
ALLOWED_ORIGINS=

# ── Security ──────────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
