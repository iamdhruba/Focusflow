# ─────────────────────────────────────────────────────────────────────────────
#  FocusFlow Flutter App — Environment Variables
#  Copy this file to `.env` and fill in your values.
#  NEVER commit `.env` to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
# For local dev: http://10.0.2.2:5000/api/v1  (Android emulator → localhost)
# For production: https://api.focusflow.app/api/v1
API_BASE_URL=http://10.0.2.2:5000/api/v1

# Background sync interval in minutes (minimum 15 per WorkManager)
SYNC_INTERVAL_MINUTES=15

# App environment: development | staging | production
APP_ENV=development
